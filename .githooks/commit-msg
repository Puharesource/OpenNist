#!/usr/bin/env sh

set -eu

commit_message_file="$1"
first_line="$(sed -n '1p' "$commit_message_file" | tr -d '\r')"

case "$first_line" in
    Merge\ *|Revert\ *)
        exit 0
        ;;
esac

pattern='^(build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)(\([a-z0-9./_-]+\))?(!)?: [^ ].+$'

if printf '%s\n' "$first_line" | grep -Eq "$pattern"; then
    exit 0
fi

cat >&2 <<'EOF'
Invalid commit message.

Use Conventional Commits:
  <type>(optional-scope): <subject>

Examples:
  feat(core): add ANSI/NIST record reader scaffold
  fix(wsq): handle empty frame metadata
  docs: document package layout
  chore(repo): update analyzer configuration

Allowed types:
  build, chore, ci, docs, feat, fix, perf, refactor, revert, style, test
EOF

exit 1
