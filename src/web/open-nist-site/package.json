{
  "name": "open-nist-site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "wasm:sync": "bun scripts/sync-opennist-wasm.mjs release",
    "wasm:sync:debug": "bun scripts/sync-opennist-wasm.mjs debug",
    "dev": "bun run wasm:sync:debug && vite",
    "build": "bun run wasm:sync && tsc -b && vite build",
    "build:cloudflare": "tsc -b && vite build",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint -c .oxlintrc.json --react-plugin --jsx-a11y-plugin src scripts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@oddbird/popover-polyfill": "^0.6.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-router": "^1.168.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.0.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.0",
    "shiki": "^4.0.2",
    "simple-icons": "^16.13.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.56.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  }
}
